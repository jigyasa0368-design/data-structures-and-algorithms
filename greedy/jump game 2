// Problem:jump game 2
// Platform: leetcode
// Time Complexity: O(n)
// Space Complexity: O(1)
// Approach: greedy

class Solution {
public:
    int jump(vector<int>& nums){
         int l=0,r=0,jumps=0;
         int n=nums.size();
         while(r<n-1){
            int farest=0;
            for(int i=l;i<=r;i++){
                farest=max(farest,nums[i]+i);
            }
             l=r+1;
             r=farest;
             jumps++;
         }   
        
        return jumps;
    }
};

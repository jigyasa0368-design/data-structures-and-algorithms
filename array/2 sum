// Problem: 2 sum
// Platform: leetcode
// Approach: hash map
// Time Complexity: O(n)
// Space Complexity: O(n)




class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        map<int,int>mpp;
       for(int i=0;i<nums.size();i++){
        int numss=nums[i];
        int moreneeded=target-numss;
        if(mpp.find(moreneeded) != mpp.end()){
            return {mpp[moreneeded] , i};
        }
         mpp[numss]=i;
       }
       return {-1,-1};
    }
};




// Problem: right View of Binary Tree
// Platform: GFG
// Time Complexity: O(n)
// Space Complexity: O(h)



class Solution {
  public:
     vector<int>ans;
    void func(Node* node,int level){
        if(node==NULL) return;

        if(level== ans.size()){
            ans.push_back(node->data);
        }
         func(node->right,level+1);
         func(node->left,level+1);
    }
    
    vector<int> rightView(Node *root) {
        //  code here
        func(root,0);
        return ans;
    }
};
